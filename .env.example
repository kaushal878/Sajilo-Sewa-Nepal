# Firebase configuration (optional). When unset, the app runs in demo mode
# with seeded read-only data and a local-storage admin override for previews.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Comma-separated list of admin email addresses
VITE_ADMIN_EMAILS=

# Comma-separated list of editor email addresses
VITE_EDITOR_EMAILS=
