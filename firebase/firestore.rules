rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null
        && request.auth.token.email != null
        && (request.auth.token.email in []); // populate via custom claims or check by token
    }

    // Public read of catalog data
    match /services/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /ministries/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /offices/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /documents/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
