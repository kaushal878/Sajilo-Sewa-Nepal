rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /service-forms/{file=**} {
      allow read: if true;
      allow write: if request.auth != null
        && request.resource.size < 10 * 1024 * 1024; // 10 MB cap
    }
    match /documents/{file=**} {
      allow read: if true;
      allow write: if request.auth != null
        && request.resource.size < 10 * 1024 * 1024;
    }
  }
}
